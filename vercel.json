{
  "buildCommand": "npm run build && npm run build:docs",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "framework": null,
  "github": {
    "enabled": true,
    "autoAlias": false
  },
  "redirects": [
    {
      "source": "/docs",
      "destination": "/docs/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
